{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ServiceUrls": {
    "Identity": "https://localhost:5001"
  },
  "GrpcSettings": {
    "UsersServiceUrl": "http://localhost:5053"
  },
  "JwtSettings": {
    "Secret": "your_super_long_secret_key_at_least_32_chars",
